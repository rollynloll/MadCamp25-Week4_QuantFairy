# madcamp-week4/.env.example
# 이 파일을 .env로 복사한 뒤 실제 값을 채워 넣으세요.
# cp .env.example .env

# ── Alpaca 브로커 ──────────────────────────────────────────
# https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY_ID=PKxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_API_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALAPCA_API_BASE_URL=https://paper-api.alpaca.markets

# true = 페이퍼 트레이딩 (기본값)  |  false = 실거래
ALPACA_PAPER=true

# ── 사용자 ────────────────────────────────────────────────
DEFAULT_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
